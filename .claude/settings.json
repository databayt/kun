{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "fallbackModel": ["claude-opus-4-8", "claude-sonnet-5"],
  "env": {
    "CODEBASE_PATH": "/Users/abdout/codebase",
    "CODEBASE_REPO": "databayt/codebase",
    "CODEBASE_OWNER": "databayt",
    "CODEBASE_NAME": "codebase",
    "DEV_PORT": "3000",
    "OSS_PATH": "/Users/abdout/oss",
    "GITHUB_USER": "abdout"
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PROJECT_DIR}/.claude/hooks/session-engine-context.sh\""
          },
          {
            "type": "command",
            "command": "[ -f \"$HOME/.claude/hooks/session-maintain-status.sh\" ] && bash \"$HOME/.claude/hooks/session-maintain-status.sh\"; exit 0"
          }
        ]
      }
    ],
    "ConfigChange": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "cd \"${CLAUDE_PROJECT_DIR}\" && { node .claude/scripts/generate-vocab.mjs --check >/dev/null 2>&1 || echo 'vocabulary drifted — run: node .claude/scripts/generate-vocab.mjs'; bash .claude/scripts/build-plugin.sh --check >/dev/null 2>&1 || echo 'plugins drifted — run: bash .claude/scripts/build-plugin.sh'; }; exit 0",
            "async": true
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash(pnpm dev)",
        "hooks": [
          {
            "type": "command",
            "command": "lsof -ti:3000 | xargs kill -9 2>/dev/null; exit 0"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PROJECT_DIR}/.claude/hooks/block-destructive-bash.sh\""
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash(pnpm dev)",
        "hooks": [
          {
            "type": "command",
            "command": "sleep 2 && open -a 'Google Chrome' http://localhost:3000 &"
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "json=$(cat); p=$(printf '%s' \"$json\" | jq -r '.tool_input.file_path // empty' 2>/dev/null); [ -z \"$p\" ] && p=\"${FILE_PATH:-}\"; if [ -n \"$p\" ] && [[ \"$p\" =~ \\.(ts|tsx|js|jsx|json|css|md)$ ]]; then npx prettier --write \"$p\" 2>/dev/null; fi; exit 0"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "echo \"[$(date '+%Y-%m-%d %H:%M:%S')] Session ended\" >> ~/.claude/session-log.txt"
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "osascript -e 'display notification \"Claude Code needs attention\" with title \"Captain\"' 2>/dev/null; exit 0"
          }
        ]
      }
    ]
  }
}
