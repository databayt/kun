# Kun env template. Copy to .env and fill in. NEVER create .env.local.

# ── Auth ─────────────────────────────────────────────────────────────────
AUTH_SECRET=

# ── GitHub (report pipeline writes issues here) ───────────────────────────
GITHUB_PERSONAL_ACCESS_TOKEN=
GITHUB_REPO=databayt/kun

# ── Anthropic Claude (Haiku 4.5 for report triage) ────────────────────────
ANTHROPIC_API_KEY=

# ── Upstash Redis (rate limit + dedup ledger + corroboration counters) ────
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ── Cloudflare Turnstile (captcha for anonymous reports) ──────────────────
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# ── Report pipeline ───────────────────────────────────────────────────────
# Salt for IP hashing so DB/Upstash leaks don't expose raw IPs.
REPORT_IP_SALT=

# ── Hermes Integration (gateway lane — see /docs/hermes) ─────────────────
# Server-side endpoint the Social Hub actions call (key stays server-side).
HERMES_API_URL=
HERMES_API_KEY=
# Client-visible URL shown in the Social Hub connection panel.
NEXT_PUBLIC_HERMES_API_URL=

# ── Telegram (direct Bot API egress for the Social Hub) ──────────────────
# One-time setup: @BotFather → bot token; create the brand channel; add the
# bot as channel admin. TELEGRAM_CHANNEL_ID is @username or -100… numeric id.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHANNEL_ID=
# PRIVATE chat for auto-post draft reviews. Never reuse TELEGRAM_CHANNEL_ID here —
# review messages carry a one-click publish link and must not hit the brand channel.
TELEGRAM_REVIEW_CHAT_ID=

# ── Facebook (direct Graph API egress, per product) ──────────────────────
# One Page + one permanent Page token per brand. Requires a Meta **Business**
# app (Consumer apps can never hold Pages permissions) with pages_manage_posts,
# pages_read_engagement, pages_show_list. Suffix = product id, uppercased.
FACEBOOK_PAGE_ID_HOGWARTS=
FACEBOOK_PAGE_ACCESS_TOKEN_HOGWARTS=
FACEBOOK_PAGE_ID_MKAN=
FACEBOOK_PAGE_ACCESS_TOKEN_MKAN=
FACEBOOK_PAGE_ID_DATABAYT=
FACEBOOK_PAGE_ACCESS_TOKEN_DATABAYT=
# Legacy unsuffixed pair — hogwarts fallback only, kept for backward compat.
FACEBOOK_PAGE_ID=
FACEBOOK_PAGE_ACCESS_TOKEN=

# ── Auto-post cron (draft → approve → publish; never unattended) ─────────
# Guards /api/social/cron AND signs the one-click approval links. Vercel sends
# it as `Authorization: Bearer $CRON_SECRET`. Required — no secret, no cron.
CRON_SECRET=
# Comma-separated product ids opted in to daily drafting. EMPTY = nothing
# auto-drafts. e.g. hogwarts,databayt
SOCIAL_AUTOPOST_PRODUCTS=
# hermes (default — hands the ask to the gateway) | anthropic (drafts server-side
# via the API; opt-in because engine billing is subscription-only).
SOCIAL_DRAFT_SOURCE=
SOCIAL_DRAFT_MODEL=
# ar (default, Arabic-first) | en
SOCIAL_DRAFT_LOCALE=
# Hermes channel that receives drafts for review. Default: slack.
SOCIAL_REVIEW_CHANNEL=
# Origin used to build approval links. Defaults to the request origin.
SOCIAL_PUBLIC_URL=

