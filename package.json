    "crawl:anthropic:dry": "tsx --env-file=.env scripts/crawl-anthropic/index.ts --dry-run",
    "crawl:anthropic:upload-only": "tsx --env-file=.env scripts/crawl-anthropic/index.ts --upload-only"
  },
  "dependencies": {
