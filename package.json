{
  "name": "kun",
  "version": "1.0.0",
  "description": "Remote AI Development Infrastructure - كن (Be!)",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:turbo": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "echo 'no test runner configured yet' && exit 0",
    "postinstall": "fumadocs-mdx",
    "prepare": "husky",
    "setup:phase1": "bash scripts/phase1/setup.sh",
    "setup:phase2": "sudo bash scripts/phase2/setup.sh",
    "setup:phase3": "bash scripts/phase3/setup.sh",
    "health": "bash scripts/monitoring/health-check.sh",
    "status": "bash scripts/status.sh"
  },
  "dependencies": {
    "@auth/core": "^0.34.3",
    "@radix-ui/react-accordion": "^1.2.12",
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@tabler/icons-react": "^3.41.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "framer-motion": "^12.38.0",
    "front-matter": "^4.0.2",
    "fumadocs-core": "^16.7.11",
    "fumadocs-mdx": "^14.2.11",
    "geist": "^1.7.0",
    "gray-matter": "^4.0.3",
    "jotai": "^2.19.1",
    "lucide-react": "^1.7.0",
    "next": "16.2.2",
    "next-auth": "5.0.0-beta.30",
    "next-themes": "^0.4.6",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "server-only": "^0.0.1",
    "shiki": "^4.0.2",
    "tailwind-merge": "^3.5.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.6.0",
    "@commitlint/config-conventional": "^19.6.0",
    "@tailwindcss/postcss": "^4.2.2",
    "@types/node": "^25.5.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "husky": "^9.1.7",
    "lint-staged": "^15.2.10",
    "prettier": "^3.4.2",
    "rehype-pretty-code": "^0.14.3",
    "tailwindcss": "^4.2.2",
    "typescript": "^6.0.2"
  },
  "keywords": [
    "claude-code",
    "remote-development",
    "tailscale",
    "tmux",
    "ai-infrastructure",
    "documentation"
  ],
  "author": "Databayt",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/databayt/kun.git"
  },
  "engines": {
    "node": ">=20.0.0"
  }
