    "fumadocs-mdx": "^14.2.11",
    "geist": "^1.7.0",
    "gray-matter": "^4.0.3",
    "jotai": "^2.19.1",
    "lucide-react": "^1.7.0",
    "next": "16.2.2",
    "next-auth": "5.0.0-beta.30",
    "next-themes": "^0.4.6",
    "react": "19.2.4",
