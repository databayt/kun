{
  "name": "kun",
  "version": "1.0.0",
  "description": "Remote AI Development Infrastructure - كن (Be!)",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:turbo": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "postinstall": "fumadocs-mdx",
